# ============================================
# OpenClaw 一键配置 - 环境变量
# 复制此文件为 .env 并填入你的真实值
# cp .env.example .env && nano .env
# ============================================

# ------ 模型供应商（New-api）------
# 你的 New-api 地址，末尾必须有 /v1
NEWAPI_BASE_URL=https://your-newapi.com/v1
# 在 New-api「令牌管理」中生成
NEWAPI_API_KEY=sk-xxxx

# ------ 模型选择 ------
PRIMARY_MODEL=claude-sonnet-4-20260514
THINKING_MODEL=claude-opus-4-20260514

# ------ 微信（官方 ClawBot 插件，可选）------
# 设为 yes 则安装微信插件，安装后需扫码授权
# 前置条件：iOS 微信 8.0.70+ → 设置 → 插件 → 能看到 ClawBot
SETUP_WECHAT=no

# ------ 搜索（可选）------
# https://brave.com/search/api/ 获取
BRAVE_API_KEY=BSA_xxxx

# ------ 时区 ------
TZ=Asia/Shanghai

# ------ 用户信息（用于生成 User.md）------
USER_NAME=你的名字
USER_LANG=中文
