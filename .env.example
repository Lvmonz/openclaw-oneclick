# ============================================
# OpenClaw 一键配置 - 环境变量
# 复制此文件为 .env 并填入你的真实值
# cp .env.example .env && nano .env
# ============================================

# ------ 安装模式 ------
# lite = 简易版（无 Docker，本地运行）
# full = 满血版（Docker 容器化 + 独立浏览器镜像）
INSTALL_MODE=full

# ------ 模型供应商 ------
# 支持: anthropic / openai / openrouter / deepseek / siliconflow / kimi / custom
PROVIDER_NAME=openrouter

# API 地址，末尾必须有 /v1
NEWAPI_BASE_URL=https://openrouter.ai/api/v1

# API Key（OpenRouter: sk-or-xxx / Anthropic: sk-ant-xxx / OpenAI: sk-xxx）
NEWAPI_API_KEY=sk-or-xxxx

# API 协议格式: openai-completions（大多数供应商） / anthropic-messages（Anthropic 官方）
API_FORMAT=openai-completions

# ------ 模型选择 ------
# OpenRouter 格式: anthropic/claude-sonnet-4 / openai/gpt-4o
# 官方格式: claude-sonnet-4-20260514 / gpt-4o
PRIMARY_MODEL=anthropic/claude-sonnet-4
THINKING_MODEL=anthropic/claude-opus-4

# ------ 通讯频道（可多选）------
SETUP_WECHAT=no
SETUP_DINGTALK=no
SETUP_TELEGRAM=no
SETUP_FEISHU=no
SETUP_QQ=no
SETUP_CUSTOM_CHANNEL=no
CUSTOM_CHANNEL_WEBHOOK_URL=
CUSTOM_CHANNEL_TOKEN=
CUSTOM_CHANNEL_MSG_FORMAT=json

# ------ 浏览器 Sidecar（可选，仅 full 模式）------
# 设为 yes 则启动独立浏览器容器（需额外 2GB 内存）
SHARE_CHROME=no

# ------ 时区 ------
TZ=Asia/Shanghai

# ------ 用户信息（用于生成 User.md）------
USER_NAME=你的名字
USER_LANG=中文
